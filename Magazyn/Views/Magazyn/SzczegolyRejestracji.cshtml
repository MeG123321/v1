@model Magazyn.Models.SzczegolyRejestracjiVm
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Szczegóły rejestracji";
    ViewData["ActivePage"] = "StanyMagazynowe";
}

<a asp-action="StanyMagazynowe" class="back-link">← Powrót do stanów magazynowych</a>

<h2>Szczegóły rejestracji</h2>

<div class="search-bar" style="max-width:700px;">
    <div class="tabelka">
        <div>
            <label>Nazwa towaru</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.NazwaTowaru</p>
        </div>
        <div>
            <label>Rodzaj towaru</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.RodzajTowaru</p>
        </div>
        <div>
            <label>Jednostka miary</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.JednostkaMiary</p>
        </div>
        <div>
            <label>Ilość</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@(Model.Ilosc?.ToString("0.###") ?? "-")</p>
        </div>
        <div>
            <label>Cena netto</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@(Model.CenaNetto?.ToString("0.00") ?? "-") zł</p>
        </div>
        <div>
            <label>Stawka VAT</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.StawkaVat</p>
        </div>
        <div class="col-span-2">
            <label>Opis</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@(Model.Opis ?? "-")</p>
        </div>
        <div>
            <label>Dostawca</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@(Model.Dostawca ?? "-")</p>
        </div>
        <div>
            <label>Data dostawy</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@(Model.DataDostawy ?? "-")</p>
        </div>
        <div>
            <label>Data rejestracji</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.DataRejestracji</p>
        </div>
        <div>
            <label>Pracownik rejestrujący</label>
            <p style="color:var(--text-bright);margin:0;padding:10px 0;">@Model.ImieNazwiskoPracownika</p>
        </div>
    </div>
    <div class="btn-group mt-30">
        <a asp-action="StanyMagazynowe" class="btn-secondary">Zamknij</a>
    </div>
</div>

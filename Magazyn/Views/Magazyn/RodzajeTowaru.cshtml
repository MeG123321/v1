@model List<Magazyn.Models.TowarRodzajVm>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Rodzaje towarów";
    ViewData["ActivePage"] = "RodzajeTowaru";
}

<h2>Rodzaje towarów</h2>

@if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}
@if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
{
    <div class="validation-summary">@TempData["ErrorMessage"]</div>
}

<div class="search-bar search-bar--narrow">
    <p class="section-caption">Dodaj nowy rodzaj</p>
    <form asp-action="RejestracjaTowaru" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div class="tabelka">
            <div class="form-group">
                <label for="nazwa">Nazwa rodzaju *</label>
                <input type="text" id="nazwa" name="nazwa" placeholder="Podaj nazwę rodzaju towaru" />
            </div>
        </div>
        <div class="btn-group">
            <button type="submit" class="btn-primary">Dodaj</button>
        </div>
    </form>
</div>

<div class="tabelka-wyniki">
    <table>
        <thead>
            <tr>
                <th>Nazwa rodzaju</th>
                <th>Liczba towarów</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="3" class="no-results">Brak zdefiniowanych rodzajów towarów</td>
                </tr>
            }
            else
            {
                foreach (var typeRow in Model)
                {
                    <tr>
                        <td>
                            <span id="nazwa-@typeRow.Id">@typeRow.Nazwa</span>
                            <form id="edit-form-@typeRow.Id" method="post" asp-action="EdytujRodzaj" class="edit-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@typeRow.Id" />
                                <input type="text" name="nazwa" value="@typeRow.Nazwa" class="inline-input" />
                                <button type="submit" class="btn-primary btn-compact ml-8">Zapisz</button>
                                <button type="button" class="btn-secondary btn-compact ml-4" onclick="cancelEdit(@typeRow.Id)">Anuluj</button>
                            </form>
                        </td>
                        <td>@typeRow.LiczbaTowarow</td>
                        <td>
                            <button type="button" class="btn-secondary mr-4" id="edit-btn-@typeRow.Id" onclick="showEdit(@typeRow.Id)">Edytuj</button>
                            @if (typeRow.LiczbaTowarow == 0)
                            {
                                <form method="post" asp-action="UsunRodzaj" class="inline-form" onsubmit="return confirm('Czy na pewno usunąć ten rodzaj?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@typeRow.Id" />
                                    <button type="submit" class="btn-secondary btn-danger">Usuń</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted-small">Przypisany do towarów</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
function showEdit(id) {
    document.getElementById('nazwa-' + id).style.display = 'none';
    document.getElementById('edit-btn-' + id).style.display = 'none';
    document.getElementById('edit-form-' + id).style.display = 'block';
}
function cancelEdit(id) {
    document.getElementById('nazwa-' + id).style.display = '';
    document.getElementById('edit-btn-' + id).style.display = '';
    document.getElementById('edit-form-' + id).style.display = 'none';
}
</script>
}

@model List<Magazyn.Models.Dtos.ForgottenRowDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Magazyn GiTA - Użytkownicy zapomniani (RODO)";
    ViewData["ActivePage"] = "ForgottenUsers";
}

<h2>Użytkownicy zapomniani (RODO)</h2>

<div class="search-bar">
    <form method="get" asp-controller="Uzytkownicy" asp-action="ForgottenUsers">
        <div class="tabelka">
            <div class="col-span-2">
                <label for="fname">Imię i nazwisko (po zapomnieniu)</label>
                <input type="text" id="fname" name="fname" value="@ViewBag.Fname" placeholder="np. Abc Xyz">
            </div>
            <div>
                <label for="adminId">ID admina</label>
                <input type="text" id="adminId" name="adminId" value="@ViewBag.AdminId" placeholder="np. 1">
            </div>
        </div>

        <div class="btn-group">
            <button type="submit" class="btn-primary">Wyszukaj</button>
            <a asp-controller="Uzytkownicy" asp-action="ForgottenUsers" class="btn-secondary">Wyczyść</a>
        </div>
    </form>
</div>

<div class="tabelka-wyniki">
    <table>
        <thead>
            <tr>
                <th>Identyfikator</th>
                <th>Imię i nazwisko po zapomnieniu</th>
                <th>Data zapomnienia</th>
                <th>Administrator wykonujący</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="no-results">Brak wyników</td>
                </tr>
            }
            else
            {
                foreach (var forgottenUser in Model)
                {
                    <tr>
                        <td>@forgottenUser.Id</td>
                        <td>@forgottenUser.FullNameAfterForget</td>
                        <td>@forgottenUser.DataZapomnienia</td>
                        <td><strong>@forgottenUser.AdminName</strong></td>
                        <td><a class="btn-secondary" asp-controller="Uzytkownicy" asp-action="UserDetails" asp-route-id="@forgottenUser.Id">Szczegóły</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

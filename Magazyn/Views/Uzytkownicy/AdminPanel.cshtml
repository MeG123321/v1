@model List<Magazyn.Models.Dtos.UserListRowDto>

@{
    Layout = null;

    var isAdminOrManager =
        User.IsInRole("Administrator")
        || User.IsInRole("Kierownik magazynu")
        || User.IsInRole("Kierownik sprzedazy");
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Magazyn GiTA - Przegląd personelu</title>
    <link rel="stylesheet" href="~/css/style.css" />
    <style>
        .logout-btn-link {
            background: none;
            border: none;
            color: inherit;
            font: inherit;
            cursor: pointer;
            padding: 0;
            width: 100%;
            text-align: left;
            display: block;
            outline: none;
        }
    </style>
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
<div class="Wrapper">

    @if (isAdminOrManager)
    {
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>

            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel" class="active">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>

                    @if (User.IsInRole("Administrator"))
                    {
                        <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    }

                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia">Lista Uprawnień</a></li>
                    <li><partial name="_LogoutLink" /></li>
                </ul>
            </nav>
        </aside>
    }

    <main class="main">
        <header class="header">
            <div class="info">
                <a href="#" id="akcja-wyloguj">Wyloguj</a>
                <a asp-controller="Home" asp-action="Index">Strona Główna</a>
            </div>
        </header>

        @if (isAdminOrManager)
        {
            <section class="zaw">
                <h2>Baza pracowników - Magazyn GiTA</h2>

                <div class="search-bar">
                    <form method="get" asp-controller="Uzytkownicy" asp-action="AdminPanel">
                        <div class="tabelka">
                            <div>
                                <label>Login</label>
                                <input type="text" name="login" value="@ViewBag.Login">
                            </div>
                            <div>
                                <label>Imię i Nazwisko</label>
                                <input type="text" name="name" value="@ViewBag.Name">
                            </div>
                            <div>
                                <label>PESEL</label>
                                <input type="text" name="pesel" value="@ViewBag.Pesel" maxlength="11">
                            </div>
                        </div>

                        <div class="btn-group">
                            <button type="submit" class="btn-primary">Wyszukaj</button>
                            <a asp-controller="Uzytkownicy" asp-action="AdminPanel" class="btn-secondary">Wyczyść</a>
                        </div>
                    </form>
                </div>

                <div class="tabelka-wyniki">
                    <table>
                        <thead>
                            <tr>
                                <th>LOGIN</th><th>IMIĘ</th><th>NAZWISKO</th><th>EMAIL</th><th>STATUS</th><th>ROLA</th><th>AKCJE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr>
                                    <td><strong>@u.Username</strong></td>
                                    <td>@u.FirstName</td>
                                    <td>@u.LastName</td>
                                    <td>@u.Email</td>
                                    <td>@u.Status</td>
                                    <td style="color: #007bff; font-weight: bold;">@u.Rola</td>
                                    <td><a class="btn-secondary" asp-action="UserDetails" asp-route-id="@u.Id">Szczegóły</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </main>

</div>
</body>
</html>
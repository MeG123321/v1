@model Magazyn.Models.UserVm
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Magazyn GiTA - Edycja pracownika";
    ViewData["ActivePage"] = "AdminPanel";
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
}

<a asp-controller="Uzytkownicy" asp-action="UserDetails" asp-route-id="@Model.Id" class="back-link">
    &larr; Wróć do szczegółów
</a>

<h2>Edycja użytkownika: @Model.FirstName @Model.LastName</h2>

<div class="search-bar">
    <form asp-controller="Uzytkownicy"
          asp-action="EditUser"
          method="post"
          class="form-rejestracja">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <input type="hidden" asp-for="Id" />

        @* --- SEKCJA 1: DANE OSOBOWE --- *@
        <h3 class="form-section-title">Dane pracownika</h3>
        <div class="tabelka">
            <div class="form-group">
                <label asp-for="Username">Login (5–20 znaków)</label>
                <input asp-for="Username" placeholder="np. mkowalski" />
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Hasło</label>
                <input asp-for="Password"
                       type="password"
                       value=""
                       autocomplete="new-password"
                       placeholder="Zostaw puste, jeśli nie zmieniasz" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="FirstName">Imię</label>
                <input asp-for="FirstName" placeholder="np. Marek" />
                <span asp-validation-for="FirstName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName">Nazwisko</label>
                <input asp-for="LastName" placeholder="np. Kowalski" />
                <span asp-validation-for="LastName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="np. jan.kowalski@gmail.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Pesel">PESEL</label>
                <input asp-for="Pesel" maxlength="11" inputmode="numeric" placeholder="11 cyfr" />
                <span asp-validation-for="Pesel" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="DataUrodzenia">Data urodzenia</label>
                <input asp-for="DataUrodzenia" type="date" />
                <span asp-validation-for="DataUrodzenia" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="NrTelefonu">Nr telefonu</label>
                <input asp-for="NrTelefonu" maxlength="9" inputmode="numeric" placeholder="9 cyfr" />
                <span asp-validation-for="NrTelefonu" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Plec">Płeć</label>
                <select asp-for="Plec">
                    <option value="">Wybierz...</option>
                    <option value="Kobieta">Kobieta</option>
                    <option value="Mężczyzna">Mężczyzna</option>
                </select>
                <span asp-validation-for="Plec" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status">Status konta</label>
                <select asp-for="Status">
                    <option value="Aktywny">Aktywny</option>
                    <option value="Nieaktywny">Nieaktywny</option>
                </select>
                <span asp-validation-for="Status" class="field-error"></span>
            </div>
        </div>

        @* --- SEKCJA 2: ADRES --- *@
        <h3 class="form-section-title">Adres zamieszkania</h3>
        <div class="tabelka">
            <div class="form-group">
                <label asp-for="Miejscowosc">Miejscowość</label>
                <input asp-for="Miejscowosc" placeholder="np. Warszawa" />
                <span asp-validation-for="Miejscowosc" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="KodPocztowy">Kod pocztowy</label>
                <input asp-for="KodPocztowy" placeholder="00-000" />
                <span asp-validation-for="KodPocztowy" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Ulica">Ulica (opcjonalnie)</label>
                <input asp-for="Ulica" placeholder="np. Marszałkowska" />
                <span asp-validation-for="Ulica" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="NrPosesji">Nr posesji</label>
                <input asp-for="NrPosesji" placeholder="np. 12A" />
                <span asp-validation-for="NrPosesji" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="NrLokalu">Nr lokalu (opcjonalnie)</label>
                <input asp-for="NrLokalu" placeholder="np. 5" />
                <span asp-validation-for="NrLokalu" class="field-error"></span>
            </div>
        </div>

        <div class="btn-group" style="margin-top: 20px;">
            <button type="submit" class="btn-primary">Zapisz zmiany</button>
            <a asp-controller="Uzytkownicy" asp-action="UserDetails" asp-route-id="@Model.Id" class="btn-secondary">Anuluj</a>
        </div>
    </form>
</div>

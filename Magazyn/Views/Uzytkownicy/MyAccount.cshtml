@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Moje Konto</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
<div class="Wrapper">

    <partial name="_Sidebar" />

    <main class="main">
        <partial name="_TopNavbar" />

        <section class="zaw">
            <h2>Moje Konto</h2>

            <div class="search-bar">
                <div class="tabelka">
                    <div>
                        <label>Login</label>
                        <input type="text" value="@User.Identity?.Name" readonly />
                    </div>
                    <div>
                        <label>Rola</label>
                        <input type="text" value="@(
                            User.IsInRole("Administrator") ? "Administrator" :
                            User.IsInRole("Kierownik magazynu") ? "Kierownik magazynu" :
                            User.IsInRole("Kierownik sprzedazy") ? "Kierownik sprzedaży" :
                            User.IsInRole("Pracownik magazynu") ? "Pracownik magazynu" :
                            User.IsInRole("Sprzedawca") ? "Sprzedawca" : "-"
                        )" readonly />
                    </div>
                </div>
            </div>

            <div class="search-bar mt-30">
                <h3 style="color: var(--text-bright); margin-bottom: 20px;">Zmiana hasła</h3>
                <p style="color: var(--text-main); margin-bottom: 15px;">
                    Aby zmienić hasło, skontaktuj się z administratorem systemu.
                </p>
                <div class="btn-group">
                    <a asp-controller="Home" asp-action="Index" class="btn-secondary">Strona główna</a>
                </div>
            </div>
        </section>
    </main>

</div>
</body>
</html>

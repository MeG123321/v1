@model Magazyn.Models.Dtos.UserDetailsDto
@{
    Layout = null;

    // Pobieramy status i czyścimy go z białych znaków, aby porównanie było precyzyjne
    var currentStatus = Model.Status?.Trim() ?? "";
    var active = string.Equals(currentStatus, "Aktywny", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Szczegóły pracownika</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>

    <style>
        .details-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }
        .details-left {
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 260px;
        }
        .avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #f4f4f4;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(0,0,0,.08);
        }
        .avatar span { font-size: 28px; color: #ff7a00; font-weight: 800; line-height: 1; }

        .name-line { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

        .status-pill {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 12px;
            border: 1px solid rgba(0,0,0,.12);
            background: #f6fff2;
            color: #2e7d32;
        }
        .status-pill.off { 
            background: #fff3f3; 
            color: #b42318; 
            border-color: rgba(180, 35, 24, 0.2);
        }
        .subline { opacity: .85; margin-top: 4px; font-size: 13px; }

        .keyval th { width: 240px; opacity: .85; text-align: left; padding-right: 12px; white-space: nowrap; }
        .keyval td { word-break: break-word; }

        .action-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

        .role-fallback {
            display:none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
            align-items: center;
            justify-content: center;
            padding: 18px;
            z-index: 9999;
        }
        .role-fallback:target { display:flex; }
        .role-fallback .role-box { width: min(620px, 95vw); }

        .role-box {
            background: #0f0f10;
            border-radius: 14px;
            padding: 18px;
            border: 1px solid rgba(255,255,255,.12);
        }
        .role-box h3 { margin: 0 0 10px 0; color: #fff; }
        .role-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }
        .role-actions {
            display:flex;
            gap: 10px;
            justify-content:flex-end;
            margin-top: 14px;
            flex-wrap: wrap;
        }
        .close-x {
            float:right;
            color:#fff;
            text-decoration:none;
            font-size: 28px;
            line-height: 1;
            margin-top: -2px;
        }
        .note {
            font-size: 12px;
            opacity:.85;
            margin-top: 6px;
            color:#fff;
        }

        .inline-form { display:inline; }
    </style>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel" class="active">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia">Nadaj Uprawnienia</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <a asp-controller="Uzytkownicy" asp-action="AdminPanel" style="display:inline-block; margin-bottom:14px;">
                    ← Wróć do listy pracowników
                </a>

                <div class="details-top">
                    <div class="details-left">
                        <div class="avatar" aria-label="avatar">
                            <span>👤</span>
                        </div>

                        <div>
                            <div class="name-line">
                                <h2 style="margin:0;">@Model.FirstName @Model.LastName</h2>
                                
                                @* POPRAWKA WYŚWIETLANIA STATUSU *@
                                <span class="status-pill @(active ? "" : "off")">
                                    @(string.IsNullOrWhiteSpace(currentStatus) ? "Status: Nieokreślony" : $"Status: {currentStatus}")
                                </span>
                            </div>

                            <div class="subline">
                                <span style="margin-right:14px;">Login: <strong>@(Model.Username ?? "-")</strong></span>
                                <span>Rola: <strong>@(Model.Rola ?? "-")</strong></span>
                            </div>
                        </div>
                    </div>

                    <div class="action-row">
                        <a class="btn-primary"
                           asp-controller="Uzytkownicy"
                           asp-action="EditUser"
                           asp-route-id="@Model.Id"
                           style="text-decoration:none; display:inline-block; text-align:center;">
                            Edytuj
                        </a>

                        <form class="inline-form"
                              asp-controller="Uzytkownicy"
                              asp-action="ForgetUserFromDetails"
                              asp-route-id="@Model.Id"
                              method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="adminId" value="1" />
                            <button type="submit" class="btn-secondary"
                                    onclick="return confirm('Na pewno zapomnieć użytkownika?');">
                                Zapomnij użytkownika
                            </button>
                        </form>

                        <a class="btn-primary"
                           href="#role-popup"
                           style="text-decoration:none; display:inline-block; text-align:center;">
                            Nadaj uprawnienia
                        </a>
                    </div>
                </div>

                <div class="tabelka-wyniki">
                    <table class="keyval">
                        <tbody>
                            <tr><th>ID</th><td>@Model.Id</td></tr>
                            <tr><th>Email</th><td>@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</td></tr>
                            <tr><th>PESEL</th><td>@(string.IsNullOrWhiteSpace(Model.Pesel) ? "-" : Model.Pesel)</td></tr>
                            <tr><th>Data urodzenia</th><td>@(string.IsNullOrWhiteSpace(Model.DataUrodzenia) ? "-" : Model.DataUrodzenia)</td></tr>
                            <tr><th>Nr telefonu</th><td>@(string.IsNullOrWhiteSpace(Model.NrTelefonu) ? "-" : Model.NrTelefonu)</td></tr>
                            <tr><th>Płeć</th><td>@((Convert.ToInt32(Model.Plec) == 1) ? "Mężczyzna" : "Kobieta")</td></tr>
                            <tr><th>Miejscowość</th><td>@(string.IsNullOrWhiteSpace(Model.Miejscowosc) ? "-" : Model.Miejscowosc)</td></tr>
                            <tr><th>Kod pocztowy</th><td>@(string.IsNullOrWhiteSpace(Model.KodPocztowy) ? "-" : Model.KodPocztowy)</td></tr>
                            <tr><th>Ulica</th><td>@(string.IsNullOrWhiteSpace(Model.Ulica) ? "-" : Model.Ulica)</td></tr>
                            <tr><th>Nr posesji</th><td>@(string.IsNullOrWhiteSpace(Model.NrPosesji) ? "-" : Model.NrPosesji)</td></tr>
                            <tr><th>Nr lokalu</th><td>@(string.IsNullOrWhiteSpace(Model.NrLokalu) ? "-" : Model.NrLokalu)</td></tr>
                        </tbody>
                    </table>
                </div>

                @* Popup do nadawania ról *@
                <div id="role-popup" class="role-fallback">
                    <div class="role-box">
                        <a class="close-x" href="#" aria-label="Zamknij">&times;</a>
                        <h3>Nadaj uprawnienia</h3>

                        <form asp-controller="Uprawnienia" asp-action="SetRole" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="role-grid">
                                <div>
                                    <label style="color:#fff; font-weight:700;">Wybierz rolę</label>
                                    <select name="rola" required style="width:100%; padding:10px; border-radius:10px; margin-top:6px;">
                                        <option value="">Wybierz...</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Kierownik magazynu">Kierownik magazynu</option>
                                        <option value="Sprzedawca">Sprzedawca</option>
                                        <option value="Pracownik magazynu">Pracownik magazynu</option>
                                    </select>
                                    <div class="note">Po zapisaniu wrócisz do szczegółów użytkownika.</div>
                                </div>
                            </div>

                            <div class="role-actions">
                                <a class="btn-secondary" href="#" style="text-decoration:none; display:inline-block; text-align:center;">
                                    Anuluj
                                </a>
                                <button type="submit" class="btn-primary">Zapisz</button>
                            </div>
                        </form>
                    </div>
                </div>

            </section>
        </main>
    </div>
</body>
</html>
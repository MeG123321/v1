@model Magazyn.Models.Dtos.UserDetailsDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Magazyn GiTA - Szczegóły pracownika";
    ViewData["ActivePage"] = "AdminPanel";

    var statusText = Model.Status?.Trim() ?? "";
    var isActive = string.Equals(statusText, "Aktywny", StringComparison.OrdinalIgnoreCase);
}

@section Scripts {
    <script defer src="~/js/script.js"></script>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error">
        @TempData["ErrorMessage"]
    </div>
}

<a href="#"
   onclick="goBackReal(this); return false;"
   data-default-url='@Url.Action("AdminPanel", "Uzytkownicy")'
   class="back-link">
    &larr; Wróć do listy
</a>

<div class="details-top">
    <div class="details-left">
        <div class="avatar" aria-label="avatar">
            <span>&#128100;</span>
        </div>

        <div>
                <div class="name-line">
                    <h2>@Model.FirstName @Model.LastName</h2>

                    <span class="status-pill @(isActive ? "" : "off")">
                        @if (Model.IsForgotten) {
                            @:Status: Zanonimizowany (RODO)
                        } else {
                            @(string.IsNullOrWhiteSpace(statusText) ? "Status: Nieokreślony" : $"Status: {statusText}")
                        }
                    </span>
                </div>

            <div class="subline">
                <span class="subline-item">Login: <strong>@(Model.Username ?? "-")</strong></span>
                <span>Rola: <strong>@(Model.Rola ?? "-")</strong></span>
            </div>
        </div>
    </div>

    <div class="action-row">
        @if (!Model.IsForgotten)
        {
            @if (User.IsInRole("Administrator") || User.IsInRole("Kierownik magazynu"))
            {
                <a class="btn-secondary" asp-controller="Uzytkownicy" asp-action="EditUser" asp-route-id="@Model.Id">
                    Edytuj
                </a>

                <form class="inline-form" asp-controller="Account" asp-action="AdminGeneratePassword" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Czy na pewno wygenerować nowe hasło tymczasowe? Zostanie ono wysłane na e-mail pracownika.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-secondary">Generuj hasło</button>
                </form>
            }

            @if (User.IsInRole("Administrator"))
            {
                <form class="inline-form" asp-controller="Uzytkownicy" asp-action="ForgetUserFromDetails" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Na pewno zapomnieć użytkownika? Tej operacji nie da się cofnąć.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-secondary">Zapomnij użytkownika</button>
                </form>

                <a class="btn-secondary" href="#role-popup">Nadaj uprawnienia</a>
            }
        }
        else
        {
            <span class="status-pill off status-pill-readonly">Tryb tylko do odczytu</span>
        }
    </div>
</div>

<div class="tabelka-wyniki">
    <table class="keyval">
        <tbody>
            <tr><th>ID</th><td>@Model.Id</td></tr>
            <tr><th>Email</th><td>@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</td></tr>
            <tr><th>PESEL</th><td>@(string.IsNullOrWhiteSpace(Model.Pesel) ? "-" : Model.Pesel)</td></tr>
            <tr><th>Data urodzenia</th><td>@(string.IsNullOrWhiteSpace(Model.DataUrodzenia) ? "-" : Model.DataUrodzenia)</td></tr>
            <tr><th>Nr telefonu</th><td>@(string.IsNullOrWhiteSpace(Model.NrTelefonu) ? "-" : Model.NrTelefonu)</td></tr>
            <tr><th>Płeć</th><td>@((Convert.ToInt32(Model.Plec) == 1) ? "Mężczyzna" : "Kobieta")</td></tr>
            <tr><th>Miejscowość</th><td>@(string.IsNullOrWhiteSpace(Model.Miejscowosc) ? "-" : Model.Miejscowosc)</td></tr>
            <tr><th>Kod pocztowy</th><td>@(string.IsNullOrWhiteSpace(Model.KodPocztowy) ? "-" : Model.KodPocztowy)</td></tr>
            <tr><th>Ulica</th><td>@(string.IsNullOrWhiteSpace(Model.Ulica) ? "-" : Model.Ulica)</td></tr>
            <tr><th>Nr posesji</th><td>@(string.IsNullOrWhiteSpace(Model.NrPosesji) ? "-" : Model.NrPosesji)</td></tr>
            <tr><th>Nr lokalu</th><td>@(string.IsNullOrWhiteSpace(Model.NrLokalu) ? "-" : Model.NrLokalu)</td></tr>
        </tbody>
    </table>
</div>

@if (!Model.IsForgotten && User.IsInRole("Administrator"))
{
    <div id="role-popup" class="popup-overlay">
        <div class="search-bar popup-content">
            <div><h2>Nadaj uprawnienia</h2></div>
            <form asp-controller="Uprawnienia" asp-action="SetRole" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="role-grid">
                    @{
                        var availableRoles = new (string Value, string Label)[]
                        {
                            ("Administrator", "Administrator"),
                            ("Pracownik magazynu", "Pracownik magazynu"),
                            ("Sprzedawca", "Sprzedawca"),
                            ("Kierownik magazynu", "Kierownik magazynu"),
                            ("Kierownik sprzedazy", "Kierownik sprzedaży")
                        };
                    }
                    @foreach (var roleOption in availableRoles)
                    {
                        <label class="role-btn">
                            <input type="checkbox" name="rola" value="@roleOption.Value"
                                   @(Model.RoleList.Contains(roleOption.Value) ? "checked" : "") />
                            @roleOption.Label
                        </label>
                    }
                </div>
                <p class="db-info-note">Kliknij w listę powyżej, aby przełączyć uprawnienia.</p>
                <div class="action-row">
                    <a class="btn-secondary" href="#">Anuluj</a>
                    <button type="submit" class="btn-primary">Zapisz uprawnienia</button>
                </div>
            </form>
        </div>
    </div>
}

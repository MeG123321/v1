@model Magazyn.Models.UserRegistrationDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Rejestracja Pracownika</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja" class="active">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia">Nadaj Uprawnienia</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <h2>Dodaj nowego pracownika</h2>

                <div class="search-bar">
                    <form asp-controller="Uzytkownicy" asp-action="Rejestracja" method="post" class="form-rejestracja">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" style="color:#ff6b6b; margin-bottom:10px;"></div>

                        <div class="tabelka">
                            <div>
                                <label>Login (5-20 znaków)</label>
                                <input type="text" name="Username" required minlength="5" maxlength="20"
                                       value="@Model?.Username" placeholder="np. mkowalski">
                            </div>

                            <div>
                                <label>Hasło</label>
                                <input type="password"
                                       name="Password"
                                       required minlength="8" maxlength="15"
                                       pattern="^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[-,!*#$&amp;]).{8,15}$"
                                       title="Hasło 8-15 znaków. Musi zawierać: 1 wielką literę, 1 małą literę, 1 cyfrę i 1 znak specjalny z: -, , !, *, #, $, &"
                                       placeholder="np. Abcdef1!">
                            </div>

                            <div>
                                <label>Imię</label>
                                <input type="text" name="FirstName" required value="@Model?.FirstName" placeholder="np. Marek">
                            </div>

                            <div>
                                <label>Nazwisko</label>
                                <input type="text" name="LastName" required value="@Model?.LastName" placeholder="np. Kowalski">
                            </div>

                            <div>
                                <label>Email</label>
                                <input type="email" name="Email" required value="@Model?.Email" placeholder="np. jan.kowalski@gmail.com">
                            </div>

                            <div>
                                <label>PESEL</label>
                                <input type="text" name="Pesel" required maxlength="11" inputmode="numeric" pattern="\d{11}"
                                       value="@Model?.Pesel" placeholder="11 cyfr (bez spacji i myślników)">
                            </div>

                            <div>
                                <label>Data urodzenia</label>
                                <input type="date" name="DataUrodzenia" required value="@Model?.DataUrodzenia">
                            </div>

                            <div>
                                <label>Nr telefonu</label>
                                <input type="text" name="NrTelefonu" required maxlength="9" inputmode="numeric" pattern="\d{9}"
                                       value="@Model?.NrTelefonu" placeholder="9 cyfr">
                            </div>

                            <div>
                                <label>Płeć</label>
                                <select name="Plec" required>
                                    <option value="">Wybierz...</option>
                                    <option value="Kobieta" selected="@(Model?.Plec == "Kobieta" ? "selected" : null)">Kobieta</option>
                                    <option value="Mężczyzna" selected="@(Model?.Plec == "Mężczyzna" ? "selected" : null)">Mężczyzna</option>
                                </select>
                            </div>

                            <div>
                                <label>Status</label>
                                <select name="Status" required>
                                    <option value="Aktywny" selected="@(string.IsNullOrEmpty(Model?.Status) || Model?.Status == "Aktywny" ? "selected" : null)">Aktywny</option>
                                    <option value="Nieaktywny" selected="@(Model?.Status == "Nieaktywny" ? "selected" : null)">Nieaktywny</option>
                                </select>
                            </div>

                            <div>
                                <label>Rola</label>
                                <select name="Rola" required>
                                    <option value="Użytkownik" selected="@(string.IsNullOrEmpty(Model?.Rola) || Model?.Rola == "Użytkownik" ? "selected" : null)">Użytkownik</option>
                                    <option value="Moderator" selected="@(Model?.Rola == "Moderator" ? "selected" : null)">Moderator</option>
                                    <option value="Admin" selected="@(Model?.Rola == "Admin" ? "selected" : null)">Admin</option>
                                </select>
                            </div>

                            <div>
                                <label>Miejscowość</label>
                                <input type="text" name="Miejscowosc" required value="@Model?.Miejscowosc" placeholder="np. Warszawa">
                            </div>

                            <div>
                                <label>Kod pocztowy</label>
                                <input type="text" name="KodPocztowy" required pattern="\d{2}-\d{3}"
                                       value="@Model?.KodPocztowy" placeholder="00-000">
                            </div>

                            <div>
                                <label>Ulica (opcjonalnie)</label>
                                <input type="text" name="Ulica" value="@Model?.Ulica" placeholder="np. Marszałkowska">
                            </div>

                            <div>
                                <label>Nr posesji</label>
                                <input type="text" name="NrPosesji" required value="@Model?.NrPosesji" placeholder="np. 12A">
                            </div>

                            <div>
                                <label>Nr lokalu (opcjonalnie)</label>
                                <input type="text" name="NrLokalu" value="@Model?.NrLokalu" placeholder="np. 5">
                            </div>
                        </div>

                        <div class="btn-group" style="margin-top: 30px;">
                            <button type="submit" class="btn-primary">Zarejestruj pracownika</button>
                            <a class="btn-secondary" asp-controller="Uzytkownicy" asp-action="AdminPanel"
                               style="text-decoration:none; display:inline-block; text-align:center;">Anuluj</a>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </div>
</body>
</html>

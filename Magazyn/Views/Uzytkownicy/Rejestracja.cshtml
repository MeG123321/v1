@model Magazyn.Models.UserRegistrationDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Rejestracja Pracownika</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja" class="active">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia">Nadaj Uprawnienia</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <h2>Dodaj nowego pracownika</h2>

                <div class="search-bar">
                    <form asp-controller="Uzytkownicy" asp-action="Rejestracja" method="post" class="form-rejestracja">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="tabelka">
                            <div class="form-group">
                                <label asp-for="Username">Login (5–20 znaków)</label>
                                <input asp-for="Username" placeholder="np. mkowalski" />
                                <span asp-validation-for="Username" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Password">Hasło (8–15 znaków)</label>
                                <input asp-for="Password" type="password"
                                       pattern="^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[-,!*#$&amp;]).{8,15}$"
                                       title="Hasło 8–15 znaków: 1 wielka, 1 mała litera, 1 cyfra i 1 znak specjalny (-, !, *, #, $, &)"
                                       placeholder="np. Abcdef1!" />
                                <span asp-validation-for="Password" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="FirstName">Imię</label>
                                <input asp-for="FirstName" placeholder="np. Marek" />
                                <span asp-validation-for="FirstName" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="LastName">Nazwisko</label>
                                <input asp-for="LastName" placeholder="np. Kowalski" />
                                <span asp-validation-for="LastName" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Email">Email</label>
                                <input asp-for="Email" placeholder="np. jan.kowalski@gmail.com" />
                                <span asp-validation-for="Email" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Pesel">PESEL</label>
                                <input asp-for="Pesel" maxlength="11" inputmode="numeric" placeholder="11 cyfr" />
                                <span asp-validation-for="Pesel" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="DataUrodzenia">Data urodzenia</label>
                                <input asp-for="DataUrodzenia" type="date" />
                                <span asp-validation-for="DataUrodzenia" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="NrTelefonu">Nr telefonu</label>
                                <input asp-for="NrTelefonu" maxlength="9" inputmode="numeric" placeholder="9 cyfr" />
                                <span asp-validation-for="NrTelefonu" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Plec">Płeć</label>
                                <select asp-for="Plec">
                                    <option value="">Wybierz...</option>
                                    <option value="Kobieta">Kobieta</option>
                                    <option value="Mężczyzna">Mężczyzna</option>
                                </select>
                                <span asp-validation-for="Plec" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Status">Status</label>
                                <select asp-for="Status">
                                    <option value="Aktywny">Aktywny</option>
                                    <option value="Nieaktywny">Nieaktywny</option>
                                </select>
                                <span asp-validation-for="Status" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Rola">Rola</label>
                                <select asp-for="Rola">
                                    <option value="">Wybierz...</option>
                                    <option value="Administrator">Administrator</option>
                                    <option value="Kierownik magazynu">Kierownik magazynu</option>
                                    <option value="Kierownik sprzedazy">Kierownik sprzedaży</option>
                                    <option value="Sprzedawca">Sprzedawca</option>
                                    <option value="Pracownik magazynu">Pracownik magazynu</option>
                                </select>
                                <span asp-validation-for="Rola" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Miejscowosc">Miejscowość</label>
                                <input asp-for="Miejscowosc" placeholder="np. Warszawa" />
                                <span asp-validation-for="Miejscowosc" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="KodPocztowy">Kod pocztowy</label>
                                <input asp-for="KodPocztowy" placeholder="00-000" />
                                <span asp-validation-for="KodPocztowy" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Ulica">Ulica (opcjonalnie)</label>
                                <input asp-for="Ulica" placeholder="np. Marszałkowska" />
                                <span asp-validation-for="Ulica" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="NrPosesji">Nr posesji</label>
                                <input asp-for="NrPosesji" placeholder="np. 12A" />
                                <span asp-validation-for="NrPosesji" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="NrLokalu">Nr lokalu (opcjonalnie)</label>
                                <input asp-for="NrLokalu" placeholder="np. 5" />
                                <span asp-validation-for="NrLokalu" class="field-error"></span>
                            </div>
                        </div>

                        <div class="btn-group" style="margin-top: 30px;">
                            <button type="submit" class="btn-primary">Zarejestruj pracownika</button>
                            <a class="btn-secondary" asp-controller="Uzytkownicy" asp-action="AdminPanel"
                               style="text-decoration:none; display:inline-block; text-align:center;">Anuluj</a>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </div>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>

@model Magazyn.Models.RecoverPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA – Odzyskiwanie hasła</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Odzyskiwanie dostępu</p>
                <a class="przycisk-menu" asp-action="Login">← Wróć do logowania</a>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <span>System Obsługi Magazynu</span>
                </div>
            </header>

            <section class="zaw">
                <h2>Odzyskaj hasło</h2>
                <p class="text-muted">
                    Wprowadź swój login oraz adres e-mail przypisany do konta.
                </p>

                <form asp-action="RecoverPassword" method="post" class="form-rejestracja">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert-success">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <div class="tabelka">
                        <div class="form-group">
                            <label asp-for="Username">Login</label>
                            <input asp-for="Username" placeholder="Twój login użytkownika" />
                            <span asp-validation-for="Username" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email">Adres e-mail</label>
                            <input asp-for="Email" placeholder="np. jan.kowalski@magazyn.pl" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>
                    </div>

                    <div class="btn-group mt-30">
                        <button type="submit" class="btn-primary">Wyślij nowe hasło</button>
                        <a class="btn-secondary" asp-action="Login">Anuluj</a>
                    </div>
                </form>
            </section>
        </main>
    </div>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>

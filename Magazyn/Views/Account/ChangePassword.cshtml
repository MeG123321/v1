@model Magazyn.Models.ChangePasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Wymagana zmiana hasła</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        @* LEWY PANEL (Skopiowany z Edit) *@
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Bezpieczeństwo</p>
                <ul>
                    @* Użytkownik z hasłem tymczasowym ma ograniczony dostęp *@
                    <li><a href="#" class="active">Zmiana hasła</a></li>
                    <li><partial name="_LogoutLink" /></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a asp-controller="Account" asp-action="Logout">Wyloguj</a>
                    <span>Wymagana akcja</span>
                </div>
            </header>

            <section class="zaw">
                @* Usunąłem back-link, bo użytkownik MUSI zmienić hasło, nie może wrócić *@

                <h2>Wymagana zmiana hasła</h2>
                <p>Twoje obecne hasło jest tymczasowe. Ustaw nowe hasło, aby uzyskać pełny dostęp do systemu.</p>

                <div class="search-bar">
                    <form asp-controller="Account"
                          asp-action="ChangePassword"
                          method="post"
                          class="form-rejestracja">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <h3 class="form-section-title">Nowe poświadczenia</h3>
                        
                        <div class="tabelka">
                            <div class="form-group">
                                <label asp-for="NewPassword">Nowe hasło</label>
                                <input asp-for="NewPassword" 
                                       type="password" 
                                       placeholder="Minimum 8 znaków, wielka litera, cyfra" 
                                       autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="field-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ConfirmPassword">Powtórz nowe hasło</label>
                                <input asp-for="ConfirmPassword" 
                                       type="password" 
                                       placeholder="Wpisz hasło ponownie" 
                                       autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                            </div>
                        </div>

                        <div class="btn-group-final">
                            <button type="submit" class="btn-primary">Zapisz i kontynuuj</button>
                            <a asp-controller="Account" asp-action="Logout" class="btn-secondary">Anuluj i wyloguj</a>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </div>

    @* Skrypty walidacji (też skopiowane dla pewności) *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
@model Magazyn.Models.ChangePasswordViewModel
@{
    Layout = null; // Wyłączamy layout, aby użytkownik nie mógł "uciec" do menu przed zmianą hasła
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA – Wymagana zmiana hasła</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <div class="Wrapper" style="display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #f4f7f6;">
        <section class="zaw" style="max-width: 450px; width: 100%; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
            <h2 style="text-align: center; margin-bottom: 10px;">Zmień hasło</h2>
            <p style="text-align: center; color: #666; font-size: 0.9em; margin-bottom: 25px;">
                Twoje hasło jest tymczasowe. Musisz ustawić nowe hasło, aby kontynuować pracę w systemie.
            </p>

            <form asp-action="ChangePassword" method="post" class="form-rejestracja">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="validation-summary" style="color: red; margin-bottom: 15px;"></div>

                <div class="tabelka">
                    <div class="form-group">
                        <label asp-for="NewPassword">Nowe hasło</label>
                        <input asp-for="NewPassword" type="password" placeholder="Minimum 6 znaków" />
                        <span asp-validation-for="NewPassword" class="field-error" style="color: red; font-size: 0.8em;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword">Powtórz nowe hasło</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="Powtórz hasło" />
                        <span asp-validation-for="ConfirmPassword" class="field-error" style="color: red; font-size: 0.8em;"></span>
                    </div>
                </div>

                <div class="btn-group mt-30" style="display: flex; gap: 10px;">
                    <button type="submit" class="btn-primary" style="flex: 1;">Zapisz i wejdź</button>
                    <a asp-action="Logout" asp-controller="Account" class="btn-secondary" style="flex: 1; text-align: center; text-decoration: none; padding: 10px; border: 1px solid #ccc; border-radius: 4px; color: #333;">Wyloguj</a>
                </div>
            </form>
        </section>
    </div>

    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
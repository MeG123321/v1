@model Magazyn.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA – Logowanie</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body data-home-url='@Url.Action("Index","Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Wejście do systemu</p>
                <a class="przycisk-menu" asp-controller="Home" asp-action="Index">← Strona główna</a>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a> / Logowanie
                </div>
            </header>

            <section class="zaw">
                <h2>Logowanie</h2>

                <form asp-controller="Account" asp-action="Login" method="post" class="form-rejestracja">
                    @Html.AntiForgeryToken()
                    
                    @* Wyświetlanie ogólnych błędów logowania (np. "Niepoprawny login lub hasło") *@
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="tabelka">
                        <div class="form-group">
                            <label asp-for="Login"></label>
                            <input asp-for="Login" placeholder="np. JKowalski" class="form-control" />
                            <span asp-validation-for="Login" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Password"></label>
                            <input asp-for="Password" type="password" placeholder="Hasło" class="form-control" />
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <div class="form-group checkbox-group">
                            <label>
                                <input asp-for="RememberMe" /> @Html.DisplayNameFor(m => m.RememberMe)
                            </label>
                        </div>
                    </div>

                    @* Link do odzyskiwania hasła - zgodny z LG_UC1 punkt 3 *@
                    <div class="forgot-password-link">
                        <a asp-controller="Account" asp-action="ForgotPassword">Odzyskaj hasło</a>
                    </div>

                    <div class="btn-group mt-30">
                        <button type="submit" class="btn-primary">Zaloguj</button>
                        <a class="btn-secondary" asp-controller="Home" asp-action="Index">Anuluj</a>
                    </div>
                </form>
            </section>
        </main>
    </div>

    @* Skrypty do walidacji po stronie klienta (bez przeładowania strony) *@
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
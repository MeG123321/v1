@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA – Strona główna</title>

    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Przejdź</p>

                <!-- ZAMIANA: zamiast modala logowania przechodzimy na osobną stronę -->
                <a class="przycisk-menu przycisk-wyrozniony"
                   asp-controller="Account" asp-action="Login">
                    Zaloguj się
                </a>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>

                    <!-- opcjonalnie: link do panelu (i tak będzie chroniony przez [Authorize]) -->
                    <a asp-controller="Uzytkownicy" asp-action="AdminPanel">Panel</a>
                </div>
            </header>

            <section class="zaw">
                <h1>Magazyn GiTA</h1>
                <p>System korzysta z bazy: <strong>wwwroot/magazyn.db</strong></p>

                <div style="color: #57ab5a; font-size: 12px;">
                    Połączenie z bazą realizuje backend (ASP.NET + SQLite).
                </div>
            </section>
        </main>
    </div>
</body>
</html>
@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "Uprawnienia";
    var roleName = (string?)ViewBag.Rola ?? "-";
    ViewData["Title"] = $"Magazyn GiTA - Użytkownicy roli {roleName}";
}

<a asp-controller="Uprawnienia" asp-action="Uprawnienia" class="back-link">
    ← Wróć do ról
</a>

<h2>Użytkownicy z rolą: @roleName</h2>

<div class="tabelka-wyniki">
    <table>
        <thead>
            <tr>
                <th>Login</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Email</th>
                <th>PESEL</th>
                <th>Status</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="no-results">Brak użytkowników z tą rolą</td>
                </tr>
            }
            else
            {
                foreach (var userRow in Model)
                {
                    <tr>
                        <td>@userRow.Username</td>
                        <td>@userRow.FirstName</td>
                        <td>@userRow.LastName</td>
                        <td>@userRow.Email</td>
                        <td>@userRow.Pesel</td>
                        <td>@userRow.Status</td>
                        <td>
                            <a class="btn-secondary"
                               asp-controller="Uzytkownicy"
                               asp-action="UserDetails"
                               asp-route-id="@userRow.Id">
                                Szczegóły
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = null;
    var selected = (string[])(ViewBag.SelectedRoles ?? Array.Empty<string>());
    bool IsChecked(string r) => selected.Contains(r);

    var allRoles = new[]
    {
        "Administrator",
        "Pracownik magazynu",
        "Sprzedawca",
        "Kierownik magazynu",
        "Kierownik sprzedazy"
    };
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Nadaj Uprawnienia</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia" class="active">Nadaj Uprawnienia</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <h2>Nadaj uprawnienia</h2>

                <div class="search-bar">
                    <form method="get" asp-controller="Uprawnienia" asp-action="Uprawnienia">
                        <div class="tabelka">
                            @foreach (var rola in allRoles)
                            {
                                <div>
                                    <label>
                                        <input type="checkbox" name="rola" value="@rola" @(IsChecked(rola) ? "checked" : "") />
                                        @rola
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="btn-group">
                            <button type="submit" class="btn-primary">Filtruj</button>
                            <a class="btn-secondary"
                               asp-controller="Uprawnienia" asp-action="Uprawnienia">Wyczyść</a>
                        </div>
                    </form>
                </div>

                <div class="tabelka-wyniki">
                    <table>
                        <thead>
                            <tr>
                                <th>Login</th>
                                <th>Imię</th>
                                <th>Nazwisko</th>
                                <th>Email</th>
                                <th>PESEL</th>
                                <th>Status</th>
                                <th>Role</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="no-results">NIE ZNALEZIONO</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var u in Model)
                                {
                                    <tr>
                                        <td>@u.Username</td>
                                        <td>@u.FirstName</td>
                                        <td>@u.LastName</td>
                                        <td>@u.Email</td>
                                        <td>@u.Pesel</td>
                                        <td>@u.Status</td>
                                        <td>@u.Rola</td>
                                        <td>
                                            <a class="btn-secondary"
                                               asp-controller="Uzytkownicy"
                                               asp-action="UserDetails"
                                               asp-route-id="@u.Id">
                                                Szczegóły
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>


@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = null;
    var allRoles = new[] { "Administrator", "Pracownik magazynu", "Sprzedawca", "Kierownik magazynu", "Kierownik sprzedazy" };
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Magazyn GiTA - Lista Uprawnień</title>
    <link rel="stylesheet" href="~/css/style.css" />
    <style>
        .alert { padding: 15px; background: #d1ecf1; color: #0c5460; margin-bottom: 20px; border-radius: 4px; border: 1px solid #bee5eb; font-weight: bold; }
        .role-btn:has(input:checked) { background-color: #28a745 !important; color: white !important; }
        .logout-btn-link { background: none; border: none; color: inherit; font: inherit; cursor: pointer; padding: 0; width: 100%; text-align: left; display: block; outline: none; }
    </style>
</head>
<body>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>
                    @if (User.IsInRole("Administrator"))
                    {
                        <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    }
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia" class="active">Lista Uprawnień</a></li>

                    @* ZMIENIONY LOGOUT *@
                    <li><partial name="_LogoutLink" /></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    @* ZMIENIONY LOGOUT *@
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                @if (TempData["Message"] != null) { <div class="alert">@TempData["Message"]</div> }
                <h2>Lista Uprawnień</h2>

                <div class="tabelka-wyniki">
                    <table>
                        <thead>
                            <tr>
                                <th>LOGIN</th>
                                <th>IMIĘ I NAZWISKO</th>
                                <th>OBECNE ROLE</th>
                                <th>AKCJE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr>
                                    <td><strong>@u.Username</strong></td>
                                    <td>@u.FirstName @u.LastName</td>
                                    <td style="color: #007bff; font-weight: bold;">@u.Rola</td>
                                    <td><a href="#popup-@u.Id" class="btn-secondary">Zmień uprawnienia</a></td>
                                </tr>

                                <div id="popup-@u.Id" class="popup-overlay">
                                    <div class="popup-content search-bar">
                                        <h3>Edytuj role: @u.Username</h3>
                                        <form asp-action="SetRole" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />

                                            <div class="role-grid">
                                                @foreach (var r in allRoles)
                                                {
                                                    if (r == "Administrator" && !User.IsInRole("Administrator")) continue;

                                                    bool ma = u.Rola != null && u.Rola.Split(',').Any(x => x.Trim().Equals(r, StringComparison.OrdinalIgnoreCase));

                                                    <label class="role-btn">
                                                        <input type="checkbox" name="rola" value="@r" @(ma ? "checked" : "") />
                                                        @r
                                                    </label>
                                                }
                                            </div>

                                            <div style="margin-top:20px; text-align:right;">
                                                <button type="submit" class="btn-primary">Zapisz</button>
                                                <a href="#" class="btn-secondary">Anuluj</a>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
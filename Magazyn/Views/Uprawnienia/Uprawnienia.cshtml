@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Uprawnienia</title>

    <link rel="stylesheet" href="~/css/style.css" />
    <script defer src="~/js/script.js"></script>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia" class="active">Nadaj Uprawnienia</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <h2>Uprawnienia</h2>
                <p>Przeglądaj role i zakres ich uprawnień.</p>

                <div class="lista-uprawnien">
                    <div class="karta-uprawnien">
                        <div class="karta-lewa">
                            <span class="rola-badge rola-admin">Administrator</span>
                            <h3>Pełny dostęp</h3>
                            <p>Nadaje wszystkie uprawnienia</p>
                        </div>
                        <div class="karta-prawa">
                            <a asp-controller="Uprawnienia" asp-action="UsersByRole" asp-route-rola="Admin" class="btn-akcja">
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>

                    <div class="karta-uprawnien">
                        <div class="karta-lewa">
                            <span class="rola-badge rola-kierownik-mag">Kierownik magazynu</span>
                            <h3>Stany magazynowe</h3>
                            <p>Przeglądanie stanów magazynowych</p>
                        </div>
                        <div class="karta-prawa">
                            <a asp-controller="Uprawnienia" asp-action="UsersByRole" asp-route-rola="Kierownik magazynu" class="btn-akcja">
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>

                    <div class="karta-uprawnien">
                        <div class="karta-lewa">
                            <span class="rola-badge rola-kierownik-sprzedazy">Kierownik sprzedaży</span>
                            <h3>Historia sprzedaży</h3>
                            <p>Przeglądanie historii sprzedaży</p>
                        </div>
                        <div class="karta-prawa">
                            <a asp-controller="Uprawnienia" asp-action="UsersByRole" asp-route-rola="Kierownik sprzedazy" class="btn-akcja">
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>

                    <div class="karta-uprawnien">
                        <div class="karta-lewa">
                            <span class="rola-badge rola-sprzedawca">Sprzedawca</span>
                            <h3>Sprzedaż</h3>
                            <p>Rejestracja sprzedaży towarów</p>
                        </div>
                        <div class="karta-prawa">
                            <a asp-controller="Uprawnienia" asp-action="UsersByRole" asp-route-rola="Sprzedawca" class="btn-akcja">
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>

                    <div class="karta-uprawnien">
                        <div class="karta-lewa">
                            <span class="rola-badge rola-magazyn">Pracownik magazynu</span>
                            <h3>Aktualizacja stanu magazynu</h3>
                            <p>Możliwość zarejestrowania nowego towaru</p>
                        </div>
                        <div class="karta-prawa">
                            <a asp-controller="Uprawnienia" asp-action="UsersByRole" asp-route-rola="Pracownik magazynu" class="btn-akcja">
                                Wyświetl użytkowników
                            </a>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</body>
</html>

@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Magazyn GiTA - Lista Uprawnień";
    ViewData["ActivePage"] = "Uprawnienia";
    
    var roleOptions = new (string Value, string Label)[]
    {
        ("Administrator",       "Administrator"),
        ("Pracownik magazynu",  "Pracownik magazynu"),
        ("Sprzedawca",          "Sprzedawca"),
        ("Kierownik magazynu",  "Kierownik magazynu"),
        ("Kierownik sprzedazy", "Kierownik sprzedaży")
    };

    var selectedRoleFilters = (string[])(ViewBag.SelectedRoles ?? Array.Empty<string>());
}

<h2>Lista Uprawnień</h2>

<div class="search-bar">
    <form method="get" id="filterForm" asp-controller="Uprawnienia" asp-action="Uprawnienia">
        <label class="filter-label">
            Filtruj użytkowników (wybierz role):
        </label>
        
        <div class="role-grid horizontal">
            @foreach (var roleOption in roleOptions)
            {
                <label class="role-btn">
                    <input type="checkbox" name="rola" value="@roleOption.Value" 
                           onchange="this.form.submit()"
                           @(selectedRoleFilters.Contains(roleOption.Value) ? "checked" : "") />
                    @roleOption.Label
                </label>
            }
        </div>

        <div class="btn-group mt-20">
            <a class="btn-primary" asp-controller="Uprawnienia" asp-action="Uprawnienia">Wyczyść filtry</a>
        </div>
    </form>
</div>

<div class="tabelka-wyniki">
    <table>
        <thead>
            <tr>
                <th>Login</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Obecne Uprawnienia</th>
                <th>Status</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="6" class="no-results no-results-centered">
                        Brak użytkowników.
                    </td>
                </tr>
            }
            else
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.Username</strong></td>
                        <td>@user.FirstName</td>
                        <td>@user.LastName</td>
                        <td class="role-value">@user.Rola</td>
                        <td>@user.Status</td>
                        <td>
                            <a class="btn-secondary" href="#popup-@user.Id">Zmień Uprawnienia</a>
                            <a class="btn-secondary" asp-controller="Uzytkownicy" asp-action="UserDetails" asp-route-id="@user.Id">Szczegóły</a>
                        </td>
                    </tr>

                    <div id="popup-@user.Id" class="popup-overlay">
                        <div class="search-bar popup-content">
                            <div class="popup-header">
                                <h2 class="popup-title">Zarządzaj rolami: @user.FirstName @user.LastName</h2>
                                <a href="#" class="close-x">&times;</a>
                            </div>

                            <form asp-controller="Uprawnienia" asp-action="SetRole" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />

                                <div class="role-grid">
                                    @foreach (var roleOption in roleOptions)
                                    {
                                        bool hasRole = false;
                                        if (!string.IsNullOrWhiteSpace(user.Rola) && user.Rola != "-")
                                        {
                                            hasRole = user.Rola.Split(',')
                                                .Select(roleName => roleName.Trim())
                                                .Any(roleName => roleName.Equals(roleOption.Value, StringComparison.OrdinalIgnoreCase));
                                        }

                                        <label class="role-btn">
                                            <input type="checkbox" name="rola" value="@roleOption.Value" 
                                                   @(hasRole ? "checked" : "") />
                                            @roleOption.Label
                                        </label>
                                    }
                                </div>

                                <p class="db-info-note mt-20">
                                    Aktualne role są podświetlone. Zaznacz nowe i kliknij Zapisz.
                                </p>

                                <div class="btn-group btn-group-end mt-20">
                                    <a class="btn-secondary" href="#">Anuluj</a>
                                    <button type="submit" class="btn-primary">Zapisz uprawnienia</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }
        </tbody>
    </table>
</div>
